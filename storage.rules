rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Social media uploads: only owner can write, anyone authenticated can read
    match /social-media/{userId}/{allPaths=**} {
      // Anyone authenticated can view social media
      allow read: if request.auth != null;

      // Only the owner can upload/delete their own media
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   // Max 10MB per file
                   && request.resource.size < 10 * 1024 * 1024
                   // Only allow image and video content types
                   && (request.resource.contentType.matches('image/.*')
                       || request.resource.contentType.matches('video/.*'));

      allow delete: if request.auth != null
                    && request.auth.uid == userId;
    }

    // Diary images (existing)
    match /images/{userId}/{allPaths=**} {
      allow read: if request.auth != null
                  && request.auth.uid == userId;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null
                    && request.auth.uid == userId;
    }

    // Deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
