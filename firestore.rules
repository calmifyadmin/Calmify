rules_version = '2';
  service cloud.firestore {
    match /databases/{database}/documents {

      // ============================================================
      // WELLNESS FEATURES (Original)
      // ============================================================

      // Diaries collection
      match /diaries/{diaryId} {
        allow read: if request.auth != null &&
                       resource.data.ownerId == request.auth.uid;
        allow create: if request.auth != null &&
                         request.resource.data.ownerId == request.auth.uid;
        allow update: if request.auth != null &&
                         resource.data.ownerId == request.auth.uid &&
                         request.resource.data.ownerId == request.auth.uid;
        allow delete: if request.auth != null &&
                         resource.data.ownerId == request.auth.uid;
      }

      match /diaries {
        allow list: if request.auth != null;
      }

      // Wellbeing Snapshots collection
      match /wellbeing_snapshots/{snapshotId} {
        allow read: if request.auth != null &&
                       resource.data.ownerId == request.auth.uid;
        allow create: if request.auth != null &&
                         request.resource.data.ownerId == request.auth.uid;
        allow update: if request.auth != null &&
                         resource.data.ownerId == request.auth.uid &&
                         request.resource.data.ownerId == request.auth.uid;
        allow delete: if request.auth != null &&
                         resource.data.ownerId == request.auth.uid;
      }

      match /wellbeing_snapshots {
        allow list: if request.auth != null;
      }

      // Users collection (FCM Token Storage)
      match /users/{userId} {
        allow read: if request.auth != null &&
                       request.auth.uid == userId;
        allow create, update: if request.auth != null &&
                                 request.auth.uid == userId;
        allow delete: if request.auth != null &&
                         request.auth.uid == userId;

        // Avatars sub-collection: only owner can CRUD
        match /avatars/{avatarId} {
          allow read: if request.auth != null &&
                         request.auth.uid == userId;
          allow create: if request.auth != null &&
                           request.auth.uid == userId;
          allow update: if request.auth != null &&
                           request.auth.uid == userId;
          allow delete: if request.auth != null &&
                           request.auth.uid == userId;
        }
      }

      // Diary Insights collection (AI-generated)
      match /diary_insights/{insightId} {
        allow read: if request.auth != null &&
                       resource.data.ownerId == request.auth.uid;
        allow create: if request.auth != null &&
                         request.resource.data.ownerId == request.auth.uid;
        allow update: if request.auth != null &&
                         resource.data.ownerId == request.auth.uid &&
                         request.resource.data.ownerId == request.auth.uid;
        allow delete: if request.auth != null &&
                         resource.data.ownerId == request.auth.uid;
      }

      match /diary_insights {
        allow list: if request.auth != null;
      }

      // Psychological Profiles (AI-computed, read-only)
      match /psychological_profiles/{profileId} {
        allow read: if request.auth != null &&
                       resource.data.ownerId == request.auth.uid;
        allow create: if false;
        allow update: if false;
        allow delete: if request.auth != null &&
                         resource.data.ownerId == request.auth.uid;
      }

      // Profile Settings (Onboarding data)
      match /profile_settings/{userId} {
        allow read: if request.auth != null &&
                       request.auth.uid == userId;
        allow create, update: if request.auth != null &&
                                 request.auth.uid == userId;
        allow delete: if request.auth != null &&
                         request.auth.uid == userId;
      }

      // ============================================================
      // SOCIAL FEATURES (Wave 6-9)
      // ============================================================

      // --- Threads (Posts) ---
      match /threads/{threadId} {
        // Anyone authenticated can read public threads
        allow read: if request.auth != null;

        // Only authenticated users can create, must set themselves as author
        allow create: if request.auth != null &&
                         request.resource.data.authorId == request.auth.uid;

        // Author can update anything; others can only update counters
        // (likeCount via like/unlike batch, replyCount via reply creation)
        allow update: if request.auth != null &&
                         (resource.data.authorId == request.auth.uid ||
                          request.resource.data.diff(resource.data).affectedKeys()
                            .hasOnly(['likeCount', 'replyCount', 'repostCount']));

        // Only the author can delete their own thread
        allow delete: if request.auth != null &&
                         resource.data.authorId == request.auth.uid;

        // Likes sub-collection: any authenticated user can like/unlike
        match /likes/{likeId} {
          allow read: if request.auth != null;
          allow create, delete: if request.auth != null &&
                                   request.auth.uid == likeId;
        }

        // Reposts sub-collection: any authenticated user can repost/unrepost
        match /reposts/{repostUserId} {
          allow read: if request.auth != null;
          allow create, delete: if request.auth != null &&
                                   request.auth.uid == repostUserId;
        }
      }

      // --- User Profiles (Public) ---
      // Users can fully manage their own profile.
      // Other authenticated users can create/update ONLY followerCount/followingCount
      // (needed for atomic batch follow/unfollow — set() with merge on non-existent doc = create).
      match /user_profiles/{userId} {
        // Anyone authenticated can read public profiles
        allow read: if request.auth != null;

        // Owner can create freely; others can create counter-only docs (set+merge on missing profile)
        allow create: if request.auth != null &&
                         (request.auth.uid == userId ||
                          request.resource.data.keys().hasOnly(['followerCount', 'followingCount']));

        // Owner can update anything; others can only update social counters
        allow update: if request.auth != null &&
                         (request.auth.uid == userId ||
                          request.resource.data.diff(resource.data).affectedKeys()
                            .hasOnly(['followerCount', 'followingCount']));

        // Only the user can delete their own profile
        allow delete: if request.auth != null &&
                         request.auth.uid == userId;
      }

      // --- Social Graph (Following/Followers/Blocked) ---
      match /social_graph/{userId} {
        allow read: if request.auth != null;

        // Following sub-collection: user manages who THEY follow.
        // Needs create + update (batch.set() = update if doc already exists).
        match /following/{followedUserId} {
          allow read: if request.auth != null;
          allow create, update, delete: if request.auth != null &&
                                           request.auth.uid == userId;
        }

        // Followers sub-collection: the FOLLOWER writes their own entry
        // into the followee's /followers/ subcollection.
        // Needs create + update (batch.set() = update if doc already exists).
        match /followers/{followerUserId} {
          allow read: if request.auth != null;
          allow create, update, delete: if request.auth != null &&
                                           request.auth.uid == followerUserId;
        }

        // Blocked sub-collection: only the owner can manage
        match /blocked/{blockedUserId} {
          allow read: if request.auth != null &&
                         request.auth.uid == userId;
          allow create, delete: if request.auth != null &&
                                   request.auth.uid == userId;
        }
      }

      // --- Conversations (DM) ---
      match /conversations/{conversationId} {
        // Only participants can read the conversation
        allow read: if request.auth != null &&
                       request.auth.uid in resource.data.participantIds;

        // Authenticated users can create (must include themselves as participant)
        allow create: if request.auth != null &&
                         request.auth.uid in request.resource.data.participantIds;

        // Only participants can update (e.g., lastMessage)
        allow update: if request.auth != null &&
                         request.auth.uid in resource.data.participantIds;

        // Only participants can delete
        allow delete: if request.auth != null &&
                         request.auth.uid in resource.data.participantIds;

        // Messages sub-collection
        match /messages/{messageId} {
          allow read: if request.auth != null &&
                         request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
          allow create: if request.auth != null &&
                           request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds &&
                           request.resource.data.senderId == request.auth.uid;
        }

        // Typing indicators sub-collection
        match /typing/{typingUserId} {
          allow read: if request.auth != null &&
                         request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
          allow create, update, delete: if request.auth != null &&
                                           request.auth.uid == typingUserId;
        }
      }

      // --- Notifications ---
      match /notifications/{notificationId} {
        // Only the target user can read their notifications
        allow read: if request.auth != null &&
                       resource.data.userId == request.auth.uid;

        // Cloud Functions create notifications (Admin SDK bypasses rules)
        // But allow client to create for testing/direct notifications
        allow create: if request.auth != null;

        // Only the target user can update (mark as read)
        allow update: if request.auth != null &&
                         resource.data.userId == request.auth.uid;

        // Only the target user can delete
        allow delete: if request.auth != null &&
                         resource.data.userId == request.auth.uid;
      }

      // --- Subscriptions (Billing State) ---
      match /subscriptions/{userId} {
        // Only the user can read their subscription
        allow read: if request.auth != null &&
                       request.auth.uid == userId;

        // Only the user can create/update their subscription state
        allow create, update: if request.auth != null &&
                                 request.auth.uid == userId;

        // Only the user can delete
        allow delete: if request.auth != null &&
                         request.auth.uid == userId;
      }

      // ============================================================
      // DENY ALL OTHER ACCESS (MUST BE LAST RULE)
      // ============================================================
      match /{document=**} {
        allow read, write: if false;
      }
    }
  }
